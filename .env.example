# EmailJS – waitlist form (same setup as phcreationsPublic)
# Get values from https://dashboard.emailjs.com
# Create a template with variables: {{email}}, {{name}}, {{time}}

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_WAITLIST_TEMPLATE_ID=your_waitlist_template_id

# Android beta — full Expo EAS install URL (optional locally; same name as GitHub Secret / Variable).
# Production: set repository Secret OR Variable VITE_ANDROID_BETA_URL → CI writes dist/android-beta.json (not embedded in JS).
# VITE_ANDROID_BETA_URL=https://expo.dev/accounts/.../builds/...
